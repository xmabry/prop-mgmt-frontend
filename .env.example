# Google Calendar API (optional - for OAuth-based calendar integration)
# If not set, the app uses the Google Calendar URL approach (no OAuth needed)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=

# GitHub Integration (optional - pre-fill the GitHub Projects form)
VITE_GITHUB_TOKEN=
VITE_GITHUB_OWNER=
VITE_GITHUB_REPO=
